{
  "name": "@agentic-research/dpop",
  "version": "0.1.0",
  "description": "DPoP (RFC 9449) utilities and resource-server verifier SDK for notme-issued access tokens. Zero dependencies, pure Web Crypto — runs on Cloudflare Workers, Node, Deno, and browsers.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentic-research/notme.git",
    "directory": "packages/dpop"
  },
  "homepage": "https://github.com/agentic-research/notme/tree/main/packages/dpop",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "dpop",
    "rfc9449",
    "oauth2",
    "jwt",
    "proof-of-possession",
    "webcrypto"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
