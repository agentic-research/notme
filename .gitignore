# Default deny: ignore everything unless explicitly allowlisted below.
*

# Keep gitignore itself tracked.
!.gitignore
!.gitattributes
!.githooks/
!.githooks/**

# Beads: the store binary (beads.db) stays ignored — a committed binary DB has
# no git 3-way merge (rosary-05fbe0) — but the JSONL export is the tracked,
# mergeable text mirror that carries beads to clones/agents. Re-include the
# .beads dir so git descends, then allow only the JSONL (root `*` still ignores
# beads.db and its WAL sidecars inside).
!.beads/
!.beads/beads.jsonl

# Project metadata
!LICENSE
!NOTICE
!README.md
!SECURITY.md
!ARCHITECTURE.md
!Taskfile.yml
!go.work

# Shared Taskfile modules used by package-local release wrappers.
!tasks/
!tasks/**

# Root pnpm workspace (for repo-level scripts: scripts/check-sha-pins.ts,
# scripts/doc-check.ts, schema/codegen/capnp-to-ts.ts). The workspace also
# wires action/, worker/, and packages/* together so workspace deps like
# @notme/contract resolve through pnpm's symlink graph instead of relative
# imports.
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml

# Cap'n Proto schemas (source of truth for all cross-language types)
!schema/
!schema/**/*.capnp
!schema/codegen/
!schema/codegen/**

# Generated code from schemas (committed so consumers don't need capnp toolchain)
!gen/
!gen/ts/
!gen/ts/**
!gen/go/
!gen/go/**

# CF Worker — signet identity authority at auth.notme.bot
!worker/
!worker/**
!worker/src/
!worker/src/**

# Credential vault — zero-secret proxy gated by notme identity
!vault/
!vault/**

# Wasm — ley-line-sign (signing ops at edge)
!wasm/
!wasm/**

# Rust mTLS forward proxy
!proxy/
!proxy/**
proxy/target/

# GHA TypeScript action — identity exchange (zero env vars)
!action/
!action/**

# Scripts (doc-check, etc.)
!scripts/
!scripts/**

# Packaging — distroless OCI image (melange + apko)
!packages/
!packages/**

# Design docs
!docs/
!docs/**

# GitHub Actions workflows
!.github/
!.github/**

# Wrangler config contains CF resource IDs — use wrangler.toml.example as template
worker/wrangler.toml

# Explicitly ignore artifacts
.wrangler/
.dolt/
*.db
.DS_Store
node_modules/
dist/
_agent_log/

# packages/ build outputs (melange + apko produce these locally; CI publishes via secrets)
packages/out/
packages/*.tar
packages/sbom-*.spdx.json
packages/melange.rsa
packages/melange.rsa.pub

# Test outputs
worker/test-results/
worker/playwright-report/
coverage/

# built package artifacts (published, not committed)
packages/*/dist/
