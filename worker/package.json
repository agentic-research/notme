{
  "name": "notme-bot-site",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "format": "prettier --write \"public/**/*.{html,css,js}\" \"*.{ts,js,css,html,md,yml,yaml,json}\" \"src/**/*.ts\"",
    "lint:format": "prettier --check \"public/**/*.{html,css,js}\" \"*.{ts,js,css,html,md,yml,yaml,json}\" \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:local": "esbuild worker.ts --bundle --format=esm --outfile=dist/worker.js --conditions=workerd --external:cloudflare:workers --external:@cloudflare/vitest-pool-workers",
    "test:do": "vitest run --config vitest.workers.config.mts"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.7",
    "@cloudflare/workers-types": "^5.20260722.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.0",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.113.0"
  },
  "dependencies": {
    "@notme/contract": "workspace:*",
    "@notme/dpop": "workspace:*",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@peculiar/x509": "^1.14.3",
    "@simplewebauthn/server": "^13.3.0",
    "cbor-x": "^1.6.4",
    "zod": "^4.4.3"
  }
}
