{
  "name": "notme-bot-site",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "format": "prettier --write \"public/**/*.{html,css,js}\" \"*.{ts,js,css,html,md,yml,yaml,json}\" \"src/**/*.ts\"",
    "lint:format": "prettier --check \"public/**/*.{html,css,js}\" \"*.{ts,js,css,html,md,yml,yaml,json}\" \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.5",
    "@cloudflare/workers-types": "^4.20260329.1",
    "prettier": "^3.8.1",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  },
  "dependencies": {
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@peculiar/x509": "^1.14.3",
    "@simplewebauthn/server": "^13.3.0",
    "oslo": "^1.2.1",
    "zod": "^3.25.0"
  }
}
